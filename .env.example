# LiveKit Cloud (from https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_URL=https://your-project.livekit.cloud

# Exposed to the browser by Next.js (falls back to LIVEKIT_URL if not set)
LIVEKIT_API_KEY=APIxxxxxxxxxx
LIVEKIT_API_SECRET=your-livekit-api-secret

# AI Providers
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=your-deepgram-api-key

# Application
JWT_SECRET=change-this-to-a-random-secret-min-32-chars
JWT_EXPIRE_HOURS=24
DATABASE_URL=sqlite+aiosqlite:///./speakhome.db
SESSION_PAUSE_TIMEOUT_MINUTES=5
